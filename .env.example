# Model configuration
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=16
USE_GPU=false

# Optional LLM placeholders (not required for current retrieval flow)
LLM_PROVIDER=openai
LLM_MODEL=gpt-3.5-turbo
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=500
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Document processing
CHUNK_SIZE=500
CHUNK_OVERLAP=50
MIN_CHUNK_LENGTH=100
MAX_FILE_SIZE_MB=50

# Search and retrieval
DEFAULT_TOP_K=5
MAX_TOP_K=15
MIN_SIMILARITY_THRESHOLD=0.3
USE_GPU_INDEX=false
INDEX_TYPE=FlatIP

# App settings
APP_TITLE=DocuSearch
APP_ICON=📚
PAGE_LAYOUT=wide
SESSION_TIMEOUT_MINUTES=60
ENABLE_CACHING=true

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
